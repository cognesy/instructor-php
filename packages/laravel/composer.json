{
  "name": "cognesy/instructor-laravel",
  "description": "Laravel integration for Instructor PHP - Structured LLM outputs made simple",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "instructor",
    "llm",
    "openai",
    "anthropic",
    "structured-output",
    "ai",
    "machine-learning",
    "gpt",
    "claude"
  ],
  "authors": [
    {
      "name": "Dariusz Debowczyk",
      "email": "ddebowczyk@gmail.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "cognesy/agent-ctrl": "^1.22",
    "cognesy/instructor-config": "^2.0",
    "cognesy/instructor-events": "^2.0",
    "cognesy/instructor-http-client": "^2.0",
    "cognesy/instructor-http-pool": "^2.0",
    "cognesy/instructor-messages": "^2.0",
    "cognesy/instructor-polyglot": "^2.0",
    "cognesy/instructor-struct": "^2.0",
    "cognesy/instructor-utils": "^2.0",
    "cognesy/logging": "^1.22",
    "illuminate/contracts": "^10.0|^11.0|^12.0",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/console": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "pestphp/pest": "^2.0|^3.0",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "Cognesy\\Instructor\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cognesy\\Instructor\\Laravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Cognesy\\Instructor\\Laravel\\InstructorServiceProvider"
      ],
      "aliases": {
        "StructuredOutput": "Cognesy\\Instructor\\Laravel\\Facades\\StructuredOutput",
        "Inference": "Cognesy\\Instructor\\Laravel\\Facades\\Inference",
        "Embeddings": "Cognesy\\Instructor\\Laravel\\Facades\\Embeddings",
        "AgentCtrl": "Cognesy\\Instructor\\Laravel\\Facades\\AgentCtrl"
      }
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
