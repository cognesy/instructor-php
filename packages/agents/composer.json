{
  "name": "cognesy/agents",
  "description": "SDK for building custom AI agents",
  "license": "MIT",
  "homepage": "https://instructorphp.com",
  "support": {
    "issues": "https://github.com/cognesy/instructor-php/issues",
    "source": "https://github.com/cognesy/instructor-php"
  },
  "authors": [
    {
      "name": "Dariusz Debowczyk",
      "email": "ddebowczyk@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Cognesy\\Agents\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cognesy\\Agents\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3",
    "ext-fileinfo": "*",
    "ext-libxml": "*",
    "cognesy/instructor-dynamic": "^2.2",
    "cognesy/instructor-events": "^2.2",
    "cognesy/instructor-http-client": "^2.2",
    "cognesy/instructor-logging": "^2.2",
    "cognesy/instructor-messages": "^2.2",
    "cognesy/instructor-polyglot": "^2.2",
    "cognesy/instructor-sandbox": "^2.2",
    "cognesy/instructor-schema": "^2.2",
    "cognesy/instructor-struct": "^2.2",
    "cognesy/instructor-telemetry": "^2.2",
    "cognesy/instructor-utils": "^2.2"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "mockery/mockery": "^1.6",
    "icanhazstring/composer-unused": "^0.9.0",
    "jetbrains/phpstorm-attributes": "^1.2",
    "maglnet/composer-require-checker": "^4.16",
    "pestphp/pest": "^2.34",
    "phpstan/phpstan": "^1.11",
    "vimeo/psalm": "^6.0"
  },
  "scripts": {
    "tests": "@php vendor/bin/pest",
    "phpstan": "@php vendor/bin/phpstan -c phpstan.neon",
    "psalm": "@php vendor/bin/psalm"
  },
  "suggest": {},
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    },
    "sort-packages": true
  },
  "minimum-stability": "RC",
  "prefer-stable": true
}
