{
  "name": "cognesy/instructor-config",
  "description": "Lean config loading utilities for Instructor",
  "license": "MIT",
  "homepage": "https://instructorphp.com",
  "support": {
    "issues": "https://github.com/cognesy/instructor-php/issues",
    "source": "https://github.com/cognesy/instructor-php"
  },
  "authors": [
    {
      "name": "Dariusz Debowczyk",
      "email": "ddebowczyk@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Cognesy\\Config\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cognesy\\Config\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3",
    "symfony/config": "^7.0 || ^8.0",
    "symfony/yaml": "^7.0 || ^8.0"
  },
  "require-dev": {
    "pestphp/pest": "^4.0",
    "phpstan/phpstan": "^1.11",
    "vimeo/psalm": "^6.0"
  },
  "scripts": {
    "tests": "@php ../../vendor/bin/pest --configuration=phpunit.xml --bootstrap=../../vendor/autoload.php tests",
    "phpstan": "@php ../../vendor/bin/phpstan analyse -c phpstan.neon",
    "psalm": "@php ../../vendor/bin/psalm --root=../.. --config=psalm.xml"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    },
    "sort-packages": true
  },
  "minimum-stability": "RC",
  "prefer-stable": true
}
