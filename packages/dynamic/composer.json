{
  "name": "cognesy/instructor-dynamic",
  "description": "Lightweight dynamic structure record and schema builder for Instructor",
  "license": "MIT",
  "homepage": "https://instructorphp.com",
  "support": {
    "issues": "https://github.com/cognesy/instructor-php/issues",
    "source": "https://github.com/cognesy/instructor-php"
  },
  "authors": [
    {
      "name": "Dariusz Debowczyk",
      "email": "ddebowczyk@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Cognesy\\Dynamic\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cognesy\\Dynamic\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3",
    "cognesy/instructor-schema": "^2.0",
    "cognesy/instructor": "^1.22",
    "symfony/type-info": "^7.3 || ^8.0"
  },
  "require-dev": {
    "pestphp/pest": "^4.0",
    "phpstan/phpstan": "^1.11",
    "vimeo/psalm": "^6.0"
  },
  "scripts": {
    "tests": "@php -r \"\\$paths=['vendor/bin/pest','../../vendor/bin/pest']; foreach(\\$paths as \\$path){ if(is_file(\\$path)){ passthru(PHP_BINARY.' '.\\$path.' tests', \\$code); exit(\\$code);} } fwrite(STDERR, 'Could not open pest binary'.PHP_EOL); exit(1);\""
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    },
    "sort-packages": true
  },
  "minimum-stability": "RC",
  "prefer-stable": true
}
